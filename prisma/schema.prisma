// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?
  phone         String
  reason        String
  preferredTime String?
  telegramId    String?
  source        String   @default("website")
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TelegramConversationSession {
  id            Int      @id @default(autoincrement())
  chatId        String   @unique
  state         String   @default("idle")
  draftName     String?
  draftContact  String?
  preferredTime String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VkConversationSession {
  id            Int      @id @default(autoincrement())
  peerId        String   @unique
  state         String   @default("idle")
  draftName     String?
  draftContact  String?
  preferredTime String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContentPage {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  title          String
  excerpt        String
  content        String
  pageType       String   @default("page")
  published      Boolean  @default(true)
  showOnHomepage Boolean  @default(false)
  summaryPoints  Json?
  sourceLabel    String?
  sourceHref     String?
  researchLabel  String?
  researchHref   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteContent {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id           Int               @id @default(autoincrement())
  visitorId    String
  visitorName  String?
  status       String            @default("active") // active, closed
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     ChatMessage[]
  voiceInvites ChatVoiceInvite[]
  voiceEvents  ChatVoiceEvent[]

  @@index([visitorId])
  @@index([status])
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int
  sender    String      // "visitor" or "admin"
  content   String
  replyToId Int?
  deletedAt DateTime?
  deletedBy String?
  editedAt  DateTime?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([replyToId])
}

model ChatVoiceInvite {
  id        Int               @id @default(autoincrement())
  sessionId Int
  token     String            @unique
  status    String            @default("pending") // pending, active, ended, expired
  dataUsageBytes BigInt       @default(0)
  durationSeconds Int         @default(0)
  closedBy  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  expiresAt DateTime
  joinedAt  DateTime?
  endedAt   DateTime?
  session   ChatSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  signals   ChatVoiceSignal[]
  events    ChatVoiceEvent[]

  @@index([sessionId])
  @@index([status])
}

model ChatVoiceSignal {
  id         Int             @id @default(autoincrement())
  inviteId    Int
  senderRole  String
  signalType  String
  payload     Json
  createdAt   DateTime       @default(now())
  invite      ChatVoiceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId, id])
}

model ChatVoiceEvent {
  id         Int             @id @default(autoincrement())
  inviteId    Int
  sessionId   Int
  token       String
  role        String
  eventType   String
  message     String
  details     Json?
  createdAt   DateTime       @default(now())
  invite      ChatVoiceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  session     ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([inviteId, createdAt])
  @@index([token, createdAt])
}

